---
export const meta = {
  title: "Outlined Text",
  description: "Hollow outlined text effect",
  category: "text" as const,
  tags: ["outline", "stroke", "hollow"],
};

export const code = `<span style="color:transparent;-webkit-text-stroke:2px #00ffcc;font-size:2.5em;font-weight:bold;letter-spacing:0.05em">Outlined</span>`;

export const props = [
  {
    name: "strokeColor",
    type: "color" as const,
    default: "#00ffcc",
    label: "Outline Color",
    description: "Outline color",
  },
  {
    name: "strokeWidth",
    type: "slider" as const,
    default: 2,
    min: 1,
    max: 5,
    step: 0.5,
    unit: "px",
    label: "Stroke Width",
    description: "Outline thickness",
  },
  {
    name: "fontSize",
    type: "slider" as const,
    default: 2.5,
    min: 1,
    max: 5,
    step: 0.5,
    unit: "em",
    label: "Font Size",
    description: "Text size",
  },
  {
    name: "fontSizeUnit",
    type: "select" as const,
    default: "em",
    label: "Font Size Unit",
    description: "Font size unit",
    options: [
      { value: "em", label: "em" },
      { value: "px", label: "px" },
      { value: "rem", label: "rem" },
    ],
  },
];

export const codeTemplate = `<span style="color:transparent;-webkit-text-stroke:{{strokeWidth}}px {{strokeColor}};font-size:{{fontSize}}{{fontSizeUnit}};font-weight:bold;letter-spacing:0.05em">Outlined</span>`;
---

<Fragment set:html={code} />
