  category: "text" as const,
  tags: ["gradient", "sunset", "warm"],
};

export const code = `<span style="background:linear-gradient(90deg,#ff512f,#f09819,#dd2476);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:bold;font-size:2em">Sunset Text</span>`;

export const props = [
  {
    name: "color1",
    type: "color" as const,
    default: "#ff512f",
    label: "Color 1",
    description: "Gradient start color",
  },
  {
    name: "color2",
    type: "color" as const,
    default: "#f09819",
    label: "Color 2",
    description: "Gradient middle color",
  },
  {
    name: "color3",
    type: "color" as const,
    default: "#dd2476",
    label: "Color 3",
    description: "Gradient end color",
  },
  {
    name: "fontSize",
