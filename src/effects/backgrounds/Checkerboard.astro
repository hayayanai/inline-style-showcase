  tags: ["pattern", "checkerboard"],
};

export const code = `<div style="width:100%;min-height:200px;border-radius:12px;background-color:#333;background-image:linear-gradient(45deg,#555 25%,transparent 25%),linear-gradient(-45deg,#555 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#555 75%),linear-gradient(-45deg,transparent 75%,#555 75%);background-size:20px 20px;background-position:0 0,0 10px,10px -10px,-10px 0px"></div>`;

export const props = [
  {
    name: "bgColor",
    type: "color" as const,
    default: "#333333",
