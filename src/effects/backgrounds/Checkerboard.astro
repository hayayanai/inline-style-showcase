    description: "Base background color",
  },
  {
    name: "squareColor",
    type: "color" as const,
    default: "#555555",
    label: "Square Color",
    description: "Checker square color",
  },
  {
    name: "borderRadius",
    type: "slider" as const,
    default: 12,
    min: 0,
    max: 24,
    step: 1,
    unit: "px",
    label: "Border Radius",
    description: "Corner roundness",
  },
];

export const codeTemplate = `<div style="width:100%;min-height:200px;border-radius:{{borderRadius}}px;background-color:{{bgColor}};background-image:linear-gradient(45deg,{{squareColor}} 25%,transparent 25%),linear-gradient(-45deg,{{squareColor}} 25%,transparent 25%),linear-gradient(45deg,transparent 75%,{{squareColor}} 75%),linear-gradient(-45deg,transparent 75%,{{squareColor}} 75%);background-size:20px 20px;background-position:0 0,0 10px,10px -10px,-10px 0px"></div>`;
