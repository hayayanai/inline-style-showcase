---
export const meta = {
  title: "Mesh Gradient",
  description: "Mesh gradient background",
  category: "backgrounds" as const,
  tags: ["gradient", "mesh", "colorful"],
};

export const code = `<div style="width:100%;min-height:200px;border-radius:12px;background-color:#ff99ee;background-image:radial-gradient(at 40% 20%,#6366f1 0px,transparent 50%),radial-gradient(at 80% 0%,#f97316 0px,transparent 50%),radial-gradient(at 0% 50%,#84cc16 0px,transparent 50%),radial-gradient(at 80% 50%,#06b6d4 0px,transparent 50%),radial-gradient(at 0% 100%,#a855f7 0px,transparent 50%)"></div>`;

export const props = [
  {
    name: "baseColor",
    type: "color" as const,
    default: "#ff99ee",
    label: "Base Color",
    description: "Base background color",
  },
  {
    name: "accent1",
    type: "color" as const,
    default: "#6366f1",
    label: "Accent 1",
    description: "Radial color 1",
  },
  {
    name: "accent2",
    type: "color" as const,
    default: "#f97316",
    label: "Accent 2",
    description: "Radial color 2",
  },
  {
    name: "borderRadius",
    type: "slider" as const,
    default: 12,
    min: 0,
    max: 24,
    step: 1,
    unit: "px",
    label: "Border Radius",
    description: "Corner roundness",
  },
];

export const codeTemplate = `<div style="width:100%;min-height:200px;border-radius:{{borderRadius}}px;background-color:{{baseColor}};background-image:radial-gradient(at 40% 20%,{{accent1}} 0px,transparent 50%),radial-gradient(at 80% 0%,{{accent2}} 0px,transparent 50%),radial-gradient(at 0% 50%,#84cc16 0px,transparent 50%),radial-gradient(at 80% 50%,#06b6d4 0px,transparent 50%),radial-gradient(at 0% 100%,#a855f7 0px,transparent 50%)"></div>`;
---

<Fragment set:html={code} />
