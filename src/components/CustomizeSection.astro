---
import type { PropDefinition } from "../lib/effects";

interface Props {
  props: PropDefinition[];
  codeTemplate: string;
}

const { props, codeTemplate } = Astro.props;

const sliderPropNames = new Set(
  props.filter((prop) => prop.type === "slider").map((prop) => prop.name),
);

const visibleProps = props
  .filter(
    (prop) =>
      !(
        prop.type === "select" &&
        prop.name.endsWith("Unit") &&
        sliderPropNames.has(prop.name.replace(/Unit$/, ""))
      ),
  )
  .sort((a, b) => {
    if (a.type === "text" && a.name === "text") return -1;
    if (b.type === "text" && b.name === "text") return 1;
    return 0;
  });

function findSliderUnitProp(sliderName: string): PropDefinition | undefined {
  return props.find(
    (prop) => prop.type === "select" && prop.name === `${sliderName}Unit`,
  );
}
---

<div
  class="customize-section"
  data-props={JSON.stringify(props)}
  data-code-template={codeTemplate}
>
  <h2 class="customize-heading">Customize</h2>
  <div class="controls">
    {
      visibleProps.map((prop) => (
        <div class="control-group">
          <label class="control-label" for={`ctrl-${prop.name}`}>
            {prop.label}
          </label>
          {prop.type === "color" && (
            <div class="control-row">
              <input
                type="color"
                id={`ctrl-${prop.name}`}
                data-prop={prop.name}
                value={String(prop.default)}
                class="control-color"
              />
              <span class="control-value" data-value-for={prop.name}>
                {String(prop.default)}
              </span>
            </div>
          )}
          {prop.type === "slider" && (
            <div class="control-row">
              <input
                type="range"
                id={`ctrl-${prop.name}`}
                data-prop={prop.name}
                data-default-min={String(prop.min ?? 0)}
                data-default-max={String(prop.max ?? 100)}
                data-default-step={String(prop.step ?? 1)}
                value={String(prop.default)}
                min={String(prop.min ?? 0)}
                max={String(prop.max ?? 100)}
                step={String(prop.step ?? 1)}
                class="control-slider"
              />
              <input
                type="number"
                data-prop-number={prop.name}
                value={String(prop.default)}
                step={String(prop.step ?? 1)}
                class="control-number"
              />
              {!findSliderUnitProp(prop.name) && prop.unit && (
                <span class="control-unit">{prop.unit}</span>
              )}
              {findSliderUnitProp(prop.name) && (
                <select
                  id={`ctrl-${findSliderUnitProp(prop.name)?.name}`}
                  data-prop={findSliderUnitProp(prop.name)?.name}
                  class="control-value-select"
                >
                  {(findSliderUnitProp(prop.name)?.options ?? []).map((opt) => (
                    <option
                      value={opt.value}
                      selected={
                        opt.value ===
                        String(findSliderUnitProp(prop.name)?.default ?? "")
                      }
                    >
                      {opt.label}
                    </option>
                  ))}
                </select>
              )}
            </div>
          )}
          {prop.type === "select" && (
            <div class="control-row">
              <select
                id={`ctrl-${prop.name}`}
                data-prop={prop.name}
                class="control-select"
              >
                {(prop.options ?? []).map((opt) => (
                  <option
                    value={opt.value}
                    selected={opt.value === String(prop.default)}
                  >
                    {opt.label}
                  </option>
                ))}
              </select>
            </div>
          )}
          {prop.type === "text" && (
            <div class="control-row">
              <input
                type="text"
                id={`ctrl-${prop.name}`}
                data-prop={prop.name}
                value={String(prop.default)}
                class="control-text"
              />
            </div>
          )}
        </div>
      ))
    }
  </div>
</div>

<style>
  .customize-section {
    margin-top: 2rem;
  }

  .customize-heading {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
  }

  .controls {
    display: grid;
    gap: 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--overlay-light);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .control-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .control-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .control-unit {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: monospace;
    min-width: 2em;
  }

  .control-value-select {
    min-width: 4em;
    padding: 0.2rem 0.35rem;
    background: var(--overlay-subtle);
    border: 1px solid var(--overlay-medium);
    border-radius: 6px;
    color: var(--accent);
    font-family: monospace;
    font-size: 0.85rem;
  }

  .control-color {
    width: 40px;
    height: 32px;
    border: 1px solid var(--overlay-strong);
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    padding: 2px;
  }

  .control-slider {
    flex: 1;
    height: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--overlay-light);
    border-radius: 3px;
    outline: none;
  }

  .control-number {
    width: 5.5em;
    padding: 0.35rem 0.45rem;
    background: var(--overlay-subtle);
    border: 1px solid var(--overlay-medium);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 0.85rem;
    font-family: monospace;
  }

  .control-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
  }

  .control-slider::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: none;
  }

  .control-select {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: var(--overlay-subtle);
    border: 1px solid var(--overlay-medium);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 0.9rem;
  }

  .control-text {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: var(--overlay-subtle);
    border: 1px solid var(--overlay-medium);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 0.9rem;
  }
</style>

<script>
  function setupCustomizeSections() {
    document.querySelectorAll(".customize-section").forEach((section) => {
      const propsData = JSON.parse(section.getAttribute("data-props") || "[]");
      const codeTemplate = section.getAttribute("data-code-template") || "";

      const values: Record<string, string | number> = {};
      for (const prop of propsData) {
        values[prop.name] = prop.default;
      }

      function generateCode(): string {
        let result = codeTemplate;
        for (const [name, value] of Object.entries(values)) {
          result = result.replaceAll(`{{${name}}}`, String(value));
        }
        return result;
      }

      function getSliderUnit(propName: string, fallbackUnit = ""): string {
        const unitControl = propsData.find(
          (p: any) => p.name === `${propName}Unit` && p.type === "select",
        );
        if (unitControl) {
          return String(values[unitControl.name] ?? unitControl.default ?? "");
        }
        return fallbackUnit;
      }

      function updateOutputs() {
        const code = generateCode();

        const previewArea = document.getElementById("customize-preview-area");
        if (previewArea) {
          previewArea.innerHTML = code;
        }

        const codeContainer = document.getElementById(
          "customize-code-container",
        );
        if (codeContainer) {
          const codeBlock = codeContainer.querySelector(".code-block code");
          if (codeBlock) {
            codeBlock.textContent = code;
          }
          const copyBtn = codeContainer.querySelector(".copy-button");
          if (copyBtn) {
            copyBtn.setAttribute("data-copy-text", code);
          }
        }
      }

      function getSliderBounds(
        prop: any,
        unit: string,
      ): { min: number; max: number; step: number } {
        const min = Number(prop?.min ?? 0);
        const max = Number(prop?.max ?? 100);
        const step = Number(prop?.step ?? 1);

        if (unit === "px") {
          return {
            min: 1,
            max: Math.max(200, max),
            step: 1,
          };
        }

        return { min, max, step };
      }

      function applySliderBounds(propName: string) {
        const prop = propsData.find((p: any) => p.name === propName);
        if (!prop || prop.type !== "slider") {
          return;
        }

        const slider = section.querySelector(
          `[data-prop="${propName}"]`,
        ) as HTMLInputElement | null;
        const numberInput = section.querySelector(
          `[data-prop-number="${propName}"]`,
        ) as HTMLInputElement | null;

        if (!slider || !numberInput) {
          return;
        }

        const unit = getSliderUnit(propName, prop.unit);
        const bounds = getSliderBounds(prop, unit);

        slider.min = String(bounds.min);
        slider.max = String(bounds.max);
        slider.step = String(bounds.step);
        numberInput.step = String(bounds.step);

        const currentValue = Number(values[propName]);
        if (Number.isFinite(currentValue)) {
          slider.value = String(
            Math.min(bounds.max, Math.max(bounds.min, currentValue)),
          );
          numberInput.value = String(currentValue);
        }
      }

      section.querySelectorAll("[data-prop]").forEach((input) => {
        const propName = input.getAttribute("data-prop")!;
        const prop = propsData.find((p: any) => p.name === propName);

        const handler = () => {
          const val = (input as HTMLInputElement).value;
          values[propName] = prop?.type === "slider" ? parseFloat(val) : val;

          if (prop?.type === "slider") {
            const numberInput = section.querySelector(
              `[data-prop-number="${propName}"]`,
            ) as HTMLInputElement | null;
            if (numberInput) {
              numberInput.value = val;
            }
          }

          const valueDisplay = section.querySelector(
            `[data-value-for="${propName}"]`,
          );
          if (valueDisplay && prop?.type === "color") {
            valueDisplay.textContent = val;
          }

          if (prop?.type === "select" && propName.endsWith("Unit")) {
            const basePropName = propName.replace(/Unit$/, "");
            applySliderBounds(basePropName);
          }

          updateOutputs();
        };

        input.addEventListener("input", handler);
      });

      section.querySelectorAll("[data-prop-number]").forEach((numberInput) => {
        const propName = numberInput.getAttribute("data-prop-number")!;
        const sliderInput = section.querySelector(
          `[data-prop="${propName}"]`,
        ) as HTMLInputElement | null;
        const prop = propsData.find((p: any) => p.name === propName);

        if (!sliderInput || prop?.type !== "slider") {
          return;
        }

        numberInput.addEventListener("input", () => {
          const rawValue = (numberInput as HTMLInputElement).value;
          const parsedValue = parseFloat(rawValue);
          if (!Number.isFinite(parsedValue)) {
            return;
          }

          values[propName] = parsedValue;

          const min = Number(sliderInput.min);
          const max = Number(sliderInput.max);
          const clamped = Math.min(max, Math.max(min, parsedValue));
          sliderInput.value = String(clamped);

          updateOutputs();
        });
      });

      propsData
        .filter((prop: any) => prop.type === "slider")
        .forEach((prop: any) => {
          applySliderBounds(prop.name);
        });
    });
  }

  document.addEventListener("astro:page-load", setupCustomizeSections);
</script>
