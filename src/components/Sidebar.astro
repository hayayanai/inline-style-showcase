---
import { getAllEffects, getCategoryLabel, getCategories } from "../lib/effects";

interface Props {
  currentCategory: string;
  currentSlug: string;
}

const { currentCategory, currentSlug } = Astro.props;

const allEffects = getAllEffects();
const categories = getCategories();
const base = import.meta.env.BASE_URL;
---

<aside class="sidebar" id="sidebar">
  <nav class="sidebar-nav">
    <!-- Get Started section -->
    <div class="sidebar-section">
      <h3 class="sidebar-category">Get Started</h3>
      <ul class="sidebar-list">
        <li>
          <a
            href={`${base}get-started`}
            class:list={[
              "sidebar-link",
              {
                active:
                  currentCategory === "get-started" && currentSlug === "index",
              },
            ]}
          >
            Index
          </a>
        </li>
      </ul>
    </div>

    {
      categories.map((category) => {
        const effects = allEffects.get(category) ?? [];
        const isActiveCategory = currentCategory === category;
        return (
          <div class="sidebar-section">
            <h3 class="sidebar-category">{getCategoryLabel(category)}</h3>
            <ul class="sidebar-list">
              {effects.map((effect) => {
                const isActive =
                  isActiveCategory && currentSlug === effect.slug;
                return (
                  <li>
                    <a
                      href={`${base}${category}/${effect.slug}`}
                      class:list={["sidebar-link", { active: isActive }]}
                    >
                      {effect.meta.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })
    }
  </nav>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<style>
  .sidebar {
    width: 260px;
    min-width: 260px;
    height: calc(100vh - 57px);
    position: sticky;
    top: 57px;
    overflow-y: auto;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-color);
    padding: 1.5rem 0;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
  }

  .sidebar-section {
    padding: 0 0 1rem 0;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1rem;
  }

  .sidebar-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .sidebar-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    padding: 0 1.5rem;
    margin: 0 0 0.5rem 0;
  }

  .sidebar-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.4rem 1.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
    border-left: 3px solid transparent;
  }

  .sidebar-link:hover {
    color: var(--text-primary);
    background: var(--overlay-subtle);
  }

  .sidebar-link.active {
    color: var(--text-primary);
    background: var(--accent-overlay);
    border-left-color: var(--accent);
  }

  .sidebar-overlay {
    display: none;
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: -280px;
      top: 0;
      height: 100vh;
      z-index: 300;
      transition: left 0.3s ease;
      padding-top: 1.5rem;
    }

    .sidebar.open {
      left: 0;
    }

    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: var(--backdrop);
      z-index: 250;
      display: none;
    }

    .sidebar-overlay.open {
      display: block;
    }
  }
</style>

<script>
  function setupSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebarOverlay");

    function closeSidebar() {
      sidebar?.classList.remove("open");
      overlay?.classList.remove("open");
    }

    overlay?.addEventListener("click", closeSidebar);

    // Close sidebar when clicking a link (mobile)
    sidebar?.querySelectorAll(".sidebar-link").forEach((link) => {
      link.addEventListener("click", closeSidebar);
    });
  }

  document.addEventListener("astro:page-load", setupSidebar);

  // Preserve sidebar scroll position across view transitions
  document.addEventListener("astro:before-swap", (e) => {
    const oldSidebar = document.getElementById("sidebar");
    if (!oldSidebar) return;
    const scrollTop = oldSidebar.scrollTop;

    const newSidebar = e.newDocument.getElementById("sidebar");
    if (newSidebar) {
      // Apply scroll position to the incoming DOM before it's swapped in
      newSidebar.dataset.scrollTop = String(scrollTop);
    }
  });

  document.addEventListener("astro:after-swap", () => {
    const s = document.getElementById("sidebar");
    if (s?.dataset.scrollTop) {
      s.scrollTop = Number(s.dataset.scrollTop);
      delete s.dataset.scrollTop;
    }
  });
</script>
